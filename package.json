{
  "name": "Cogulator",
  "productName": "Cogulator",
  "version": "4.5.2",
  "description": "Cogulator: A Cognitive Calculator",
  "main": "src/index.js",
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "lint": "echo \"No linting configured\""
  },
  "keywords": [],
  "author": {
    "name": "The MITRE Corp",
    "email": "sestes@mitre.org"
  },
  "license": "Apache-2.0",
  "config": {
    "forge": {
      "packagerConfig": {
        "packageManager": "npm",
        "icon": "./src/icons/1024x1024"
      },
      "makers": [
        {
          "name": "@electron-forge/maker-squirrel",
          "config": {
            "name": "Cogulator",
            "setupIcon": "./src/icons/1024x1024.ico",
            "loadingGif": "./src/icons/cogulator_win_loading.gif"
          }
        },
        {
          "name": "@electron-forge/maker-zip",
          "platforms": [
            "darwin"
          ]
        },
        {
          "name": "@electron-forge/maker-deb",
          "config": {
            "icon": "./src/icons/1024x1024.icns",
            "format": "ULFO"
          }
        },
        {
          "name": "@electron-forge/maker-rpm",
          "config": {}
        }
      ]
    }
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.102.1",
    "@xenova/transformers": "^2.17.2",
    "custom-electron-titlebar": "^4.2.8",
    "dotenv": "^17.4.1",
    "electron-json-config": "^2.1.0",
    "electron-squirrel-startup": "^1.0.1",
    "glob": "^13.0.6",
    "groq-sdk": "^1.1.2",
    "jquery": "^3.5.1",
    "npm": "^11.5.2",
    "trash": "^10.0.0",
    "update-electron-app": "^3.1.1"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.10.2",
    "@electron-forge/maker-deb": "^7.10.2",
    "@electron-forge/maker-rpm": "^7.10.2",
    "@electron-forge/maker-squirrel": "^7.10.2",
    "@electron-forge/maker-zip": "^7.10.2",
    "electron": "^36.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Cogulator/Cogulator.git"
  }
}
